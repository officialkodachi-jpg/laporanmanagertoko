  </div>

  <!-- ── TAB RIWAYAT ── -->
  <div class="panel" id="panel-riwayat">
    <div class="grid-controls">
      <input type="month" class="month-select" id="riwayat-month">
      <button class="load-btn" onclick="loadRiwayat()">Tampilkan</button>
    </div>
    <div id="riwayat-container">
      <div class="empty">
        <div class="empty-icon">🗂</div>
        <div class="empty-text">Pilih bulan untuk melihat riwayat pengisian</div>
      </div>
    </div>
  </div>

</div><!-- /content -->

<!-- MODAL -->
<div class="modal-bg" id="modal">
  <div class="modal">
    <div class="modal-title">Setup URL Google Sheets</div>
    <div class="modal-sub">Paste URL dari Google Apps Script Web App. Buat dari <b>Extensions → Apps Script → Deploy → New Deployment → Web App</b>.</div>
    <input class="modal-input" id="url-input" placeholder="https://script.google.com/macros/s/...">
    <div class="modal-btns">
      <button class="modal-cancel" onclick="closeModal()">Batal</button>
      <button class="modal-save" onclick="saveUrl()">Simpan</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ─────────────────────────────────────────────
// DATA
// ─────────────────────────────────────────────
const HARIAN = [
  {kode:'D01',nama:'Kehadiran efektif di toko',kategori:'Operasional',prioritas:'Wajib',kpi:'Min. 4 jam/hari',target:'Min. 4 jam/hari'},
  {kode:'D02',nama:'Paket terkirim ke ekspedisi non-J&T (SPX dll)',kategori:'Operasional',prioritas:'Wajib',kpi:'0 komplain pengiriman',target:'100% terkirim'},
  {kode:'D03',nama:'Stok sepatu, kaos kaki & tali tersedia di toko',kategori:'Operasional',prioritas:'Wajib',kpi:'Tidak ada kehabisan mendadak',target:'Selalu ada'},
  {kode:'D04',nama:'Catatan uang diambil, setor & kembalian terisi',kategori:'Keuangan',prioritas:'Wajib',kpi:'Catatan lengkap tanpa selisih',target:'Selisih = 0'},
  {kode:'D05',nama:'Uang kembalian cukup di toko',kategori:'Operasional',prioritas:'Penting',kpi:'0 transaksi gagal karena uang receh',target:'Selalu ada'},
  {kode:'D06',nama:'Partimer datang & pulang tepat waktu',kategori:'SDM',prioritas:'Penting',kpi:'Ketepatan waktu partimer',target:'100%'},
  {kode:'D07',nama:'Inventaris toko tersedia (plastik, lakban dll)',kategori:'Inventaris',prioritas:'Penting',kpi:'Tidak ada kehabisan bahan',target:'Selalu ada'},
  {kode:'D08',nama:'Toko bersih dan rapi (cek buka & tutup)',kategori:'Visual',prioritas:'Penting',kpi:'Kondisi bersih tiap hari operasional',target:'100% hari'},
  {kode:'D09',nama:'Produk terdisplay rapi — tidak ada rak kosong',kategori:'Visual',prioritas:'Penting',kpi:'Tidak ada rak kosong/berantakan',target:'100% hari'},
  {kode:'D10',nama:'Chat WA & Instagram dibalas',kategori:'Layanan',prioritas:'Penting',kpi:'Response time ≤ 1 jam',target:'100% dibalas'},
  {kode:'D11',nama:'Partimer melayani customer dengan baik',kategori:'Layanan',prioritas:'Penting',kpi:'0 komplain tidak ditindaklanjuti',target:'100%'},
  {kode:'D12',nama:'Banner & signage layak tampil',kategori:'Visual',prioritas:'Pendukung',kpi:'Banner dalam kondisi baik',target:'100%'},
];

const EVENTS = [
  {kode:'E01',nama:'Input stok masuk dari gudang',kategori:'Operasional',frekuensi:'Mingguan',prioritas:'Penting'},
  {kode:'E02',nama:'Setor uang ke owner & laporan keuangan',kategori:'Keuangan',frekuensi:'Mingguan',prioritas:'Wajib'},
  {kode:'E03',nama:'Stok opname — aktual vs sistem',kategori:'Inventaris',frekuensi:'2x/Bulan',prioritas:'Wajib'},
  {kode:'E04',nama:'Laporan stok minus / kehilangan ke owner',kategori:'Inventaris',frekuensi:'Insidental',prioritas:'Wajib'},
  {kode:'E05',nama:'Laporan stok datang dari pabrik',kategori:'Inventaris',frekuensi:'Insidental',prioritas:'Penting'},
  {kode:'E06',nama:'Menegur partimer yang melanggar',kategori:'SDM',frekuensi:'Insidental',prioritas:'Wajib'},
  {kode:'E07',nama:'Isi shift kosong — carikan pengganti',kategori:'SDM',frekuensi:'Insidental',prioritas:'Wajib'},
  {kode:'E08',nama:'Training partimer baru',kategori:'SDM',frekuensi:'Insidental',prioritas:'Pendukung'},
  {kode:'E09',nama:'Sampaikan keluhan partimer ke owner',kategori:'SDM',frekuensi:'Insidental',prioritas:'Penting'},
];

const BULAN_NAMES = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
const DAY_SHORT = ['Min','Sen','Sel','Rab','Kam','Jum','Sab'];

// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
let checked = {};
let notes = {};
let scriptUrl = localStorage.getItem('mtg_url') || '';
let selectedEvent = null;
let selectedStatus = null;

// ─────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  setToday('tgl-harian');
  setToday('tgl-event');
  setCurrentMonth('grid-month');
  setCurrentMonth('laporan-month');
  setCurrentMonth('riwayat-month');
  renderHarian();
  renderEventGrid();
  updateConnected();
  checkTodayFilled();
  checkLaporanBadge();
});

function setToday(id) {
  const d = new Date();
  document.getElementById(id).value = d.toISOString().split('T')[0];
}

function setCurrentMonth(id) {
  const d = new Date();
  const mm = String(d.getMonth()+1).padStart(2,'0');
  document.getElementById(id).value = `${d.getFullYear()}-${mm}`;
}

// ─────────────────────────────────────────────
// TABS
// ─────────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  btn.classList.add('active');
}

// ─────────────────────────────────────────────
// RENDER HARIAN
// ─────────────────────────────────────────────
function renderHarian() {
  const list = document.getElementById('harian-list');
  list.innerHTML = '';
  const groups = ['Wajib','Penting','Pendukung'];
  const dotClass = {Wajib:'wajib',Penting:'penting',Pendukung:'pendukung'};

  groups.forEach(pri => {
    const tasks = HARIAN.filter(t => t.prioritas === pri);
    if (!tasks.length) return;
    const hdr = document.createElement('div');
    hdr.className = 'section-hdr';
    hdr.innerHTML = `<span class="section-hdr-label"><span class="pri-dot ${dotClass[pri]}"></span>${pri}</span><div class="section-hdr-line"></div>`;
    list.appendChild(hdr);
    tasks.forEach(t => {
      const el = document.createElement('div');
      el.className = 'task-item' + (checked[t.kode] ? ' done' : '');
      el.id = 'task-' + t.kode;
      el.innerHTML = `
        <div class="task-check"><span class="check-icon">✓</span></div>
        <div class="task-body">
          <div class="task-name">${t.nama}</div>
          <div class="task-meta">${t.kode} · ${t.kategori} · KPI: ${t.kpi}</div>
          <span class="task-note-toggle" onclick="toggleNote(event,'${t.kode}')">+ Tambah catatan</span>
          <textarea class="task-note-input" id="note-${t.kode}" placeholder="Catatan..." rows="2" style="display:none" onclick="event.stopPropagation()" oninput="notes['${t.kode}']=this.value"></textarea>
        </div>
      `;
      el.addEventListener('click', () => toggleCheck(t.kode));
      list.appendChild(el);
    });
  });
  updateStats();
}

function toggleCheck(kode) {
  checked[kode] = !checked[kode];
  const el = document.getElementById('task-' + kode);
  el.classList.toggle('done', checked[kode]);
  updateStats();
}

function toggleNote(e, kode) {
  e.stopPropagation();
  const ta = document.getElementById('note-' + kode);
  ta.style.display = ta.style.display === 'none' ? 'block' : 'none';
}

function updateStats() {
  const done = Object.values(checked).filter(Boolean).length;
  const total = HARIAN.length;
  const skip = total - done;
  const pct = Math.round(done/total*100);
  document.getElementById('stat-done').textContent = done;
  document.getElementById('stat-skip').textContent = skip;
  document.getElementById('stat-pct').textContent = pct + '%';
  document.getElementById('stat-pct').style.color = pct >= 90 ? 'var(--green)' : pct >= 70 ? 'var(--orange)' : 'var(--red)';
  document.getElementById('prog-pct').textContent = pct + '%';
  const fill = document.getElementById('prog-fill');
  fill.style.width = pct + '%';
  fill.className = 'prog-fill' + (pct >= 90 ? '' : pct >= 70 ? ' mid' : ' low');
}

// ─────────────────────────────────────────────
// NOTIF — cek apakah hari ini sudah diisi
// ─────────────────────────────────────────────
async function checkTodayFilled() {
  if (!scriptUrl) return;
  const today = new Date().toISOString().split('T')[0];
  const bulan = today.substring(0,7);
  try {
    const r = await fetch(`${scriptUrl}?type=cek&tanggal=${today}`);
    const d = await r.json();
    const badge = document.getElementById('badge-harian');
    const notifDiv = document.getElementById('notif-harian');
    if (d.filled) {
      badge.classList.remove('show');
      notifDiv.style.display = 'none';
    } else {
      badge.classList.add('show');
      notifDiv.style.display = 'flex';
      notifDiv.innerHTML = `<div class="notif-item">⚠ Hari ini belum ada data yang disimpan ke Google Sheets</div>`;
    }
  } catch(e) {}
}

async function checkLaporanBadge() {
  // cek apakah ada tugas < 70% di bulan ini
  if (!scriptUrl) return;
  try {
    const bulan = document.getElementById('laporan-month').value;
    const r = await fetch(`${scriptUrl}?type=rekap&bulan=${bulan}`);
    const d = await r.json();
    if (!d.tasks) return;
    const hasLow = d.tasks.some(t => t.pct < 70 && t.pct > 0);
    const badge = document.getElementById('badge-laporan');
    badge.classList.toggle('show', hasLow);
  } catch(e) {}
}

// ─────────────────────────────────────────────
// SAVE HARIAN
// ─────────────────────────────────────────────
async function saveHarian() {
  if (!scriptUrl) { openModal(); return; }
  const tanggal = document.getElementById('tgl-harian').value;
  if (!tanggal) { showToast('Pilih tanggal dulu', 'err'); return; }

  const btn = document.getElementById('save-harian-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Menyimpan...';

  const entries = HARIAN.map(t => ({
    tanggal, kode: t.kode, nama: t.nama,
    kategori: t.kategori, prioritas: t.prioritas,
    status: checked[t.kode] ? '✓' : '✗',
    catatan: notes[t.kode] || ''
  }));

  try {
    const r = await fetch(scriptUrl, {
      method: 'POST',
      body: JSON.stringify({type:'harian', entries}),
    });
    const d = await r.json();
    if (d.status === 'ok') {
      showToast('✓ Tersimpan ke Google Sheets', 'ok');
      checkTodayFilled();
      checkLaporanBadge();
    } else { showToast('Gagal: ' + (d.message||'unknown'), 'err'); }
  } catch(e) { showToast('Gagal terhubung ke Sheets', 'err'); }

  btn.disabled = false;
  btn.textContent = 'Simpan ke Google Sheets';
}

// ─────────────────────────────────────────────
// EVENT / NON-HARIAN
// ─────────────────────────────────────────────
function renderEventGrid() {
  const grid = document.getElementById('event-grid');
  grid.innerHTML = '';
  EVENTS.forEach(e => {
    const el = document.createElement('div');
    el.className = 'event-card';
    el.id = 'ev-' + e.kode;
    el.innerHTML = `
      <div class="event-kode">${e.kode}</div>
      <div class="event-nama">${e.nama}</div>
      <div class="event-meta">${e.frekuensi} · ${e.prioritas}</div>
    `;
    el.onclick = () => selectEvent(e);
    grid.appendChild(el);
  });
}

function selectEvent(ev) {
  selectedEvent = ev;
  selectedStatus = null;
  document.querySelectorAll('.event-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('ev-' + ev.kode).classList.add('selected');
  document.getElementById('sbtn-ok').className = 'status-btn';
  document.getElementById('sbtn-no').className = 'status-btn';
  document.getElementById('event-note').value = '';
  document.getElementById('event-detail').style.display = 'block';
  document.getElementById('event-detail').scrollIntoView({behavior:'smooth', block:'nearest'});
}

function setStatus(s) {
  selectedStatus = s;
  document.getElementById('sbtn-ok').className = 'status-btn' + (s==='✓'?' sel-ok':'');
  document.getElementById('sbtn-no').className = 'status-btn' + (s==='✗'?' sel-no':'');
}

async function saveEvent() {
  if (!scriptUrl) { openModal(); return; }
  if (!selectedEvent) { showToast('Pilih tugas dulu', 'err'); return; }
  if (!selectedStatus) { showToast('Pilih status dulu', 'err'); return; }
  const tanggal = document.getElementById('tgl-event').value;
  if (!tanggal) { showToast('Pilih tanggal dulu', 'err'); return; }

  try {
    const r = await fetch(scriptUrl, {
      method: 'POST',
      body: JSON.stringify({
        type: 'event',
        tanggal, kode: selectedEvent.kode, nama: selectedEvent.nama,
        kategori: selectedEvent.kategori, frekuensi: selectedEvent.frekuensi,
        prioritas: selectedEvent.prioritas, status: selectedStatus,
        catatan: document.getElementById('event-note').value
      })
    });
    const d = await r.json();
    if (d.status === 'ok') {
      showToast('✓ Tercatat', 'ok');
      document.getElementById('event-detail').style.display = 'none';
      selectedEvent = null; selectedStatus = null;
      document.querySelectorAll('.event-card').forEach(c => c.classList.remove('selected'));
    } else { showToast('Gagal: ' + (d.message||'unknown'), 'err'); }
  } catch(e) { showToast('Gagal terhubung ke Sheets', 'err'); }
}

// ─────────────────────────────────────────────
// GRID VIEW
// ─────────────────────────────────────────────
async function loadGrid() {
  if (!scriptUrl) { openModal(); return; }
  const bulan = document.getElementById('grid-month').value;
  if (!bulan) return;

  const cont = document.getElementById('grid-container');
  cont.innerHTML = '<div class="empty"><span class="spinner"></span> Memuat data...</div>';

  try {
    const r = await fetch(`${scriptUrl}?type=grid&bulan=${bulan}`);
    const d = await r.json();
    renderGrid(d, bulan);
  } catch(e) {
    cont.innerHTML = '<div class="empty"><div class="empty-icon">⚠</div><div class="empty-text">Gagal memuat data</div></div>';
  }
}

function renderGrid(data, bulan) {
  const cont = document.getElementById('grid-container');
  if (!data || !data.rows || !data.rows.length) {
    cont.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><div class="empty-text">Belum ada data untuk bulan ini</div></div>';
    return;
  }

  const [yr, mo] = bulan.split('-').map(Number);
  const daysInMonth = new Date(yr, mo, 0).getDate();

  // Build header: day numbers + day names
  let headerDays = '';
  for (let d = 1; d <= daysInMonth; d++) {
    const dayOfWeek = new Date(yr, mo-1, d).getDay();
    const isSun = dayOfWeek === 0;
    headerDays += `<th class="${isSun?'sunday':''}">${d}<br><span style="font-weight:400;opacity:0.6">${DAY_SHORT[dayOfWeek]}</span></th>`;
  }

  // Map data: kode → {day → status}
  const dataMap = {};
  data.rows.forEach(row => {
    const kode = row[1]; // kode tugas
    if (!dataMap[kode]) dataMap[kode] = {};
    // row[0] = tanggal YYYY-MM-DD
    const day = parseInt((row[0]||'').split('-')[2]) || 0;
    if (day) dataMap[kode][day] = row[5]; // status
  });

  // Build rows
  let rows = '';
  const taskPcts = {};
  HARIAN.forEach(t => {
    const taskData = dataMap[t.kode] || {};
    let doneCount = 0; let workDays = 0;
    let cells = '';
    for (let d = 1; d <= daysInMonth; d++) {
      const dayOfWeek = new Date(yr, mo-1, d).getDay();
      const isSun = dayOfWeek === 0;
      const val = taskData[d];
      if (isSun) {
        cells += `<td class="sunday"><div class="grid-cell sunday">—</div></td>`;
      } else {
        workDays++;
        const isDone = val === '✓';
        if (isDone) doneCount++;
        const isPast = new Date(yr, mo-1, d) < new Date();
        if (isDone) {
          cells += `<td><div class="grid-cell done">✓</div></td>`;
        } else if (isPast) {
          cells += `<td><div class="grid-cell empty" style="color:var(--red);opacity:0.4">✗</div></td>`;
        } else {
          cells += `<td><div class="grid-cell empty"></div></td>`;
        }
      }
    }
    const pastWorkDays = Array.from({length: daysInMonth}, (_,i)=>i+1)
      .filter(d => new Date(yr, mo-1, d).getDay() !== 0 && new Date(yr, mo-1, d) < new Date()).length;
    const pct = pastWorkDays > 0 ? Math.round(doneCount/pastWorkDays*100) : 0;
    taskPcts[t.kode] = pct;
    const pctClass = pct >= 90 ? 'pct-hi' : pct >= 70 ? 'pct-mid' : 'pct-lo';
    const priColor = t.prioritas === 'Wajib' ? 'var(--red)' : t.prioritas === 'Penting' ? 'var(--orange)' : 'var(--blue)';
    rows += `<tr>
      <td class="task-info">
        <div class="task-code" style="color:${priColor}">${t.kode}</div>
        <div class="task-name-cell">${t.nama}</div>
      </td>
      ${cells}
      <td><div class="grid-pct ${pctClass}">${pct}%</div></td>
    </tr>`;
  });

  // Avg row
  const allPcts = Object.values(taskPcts);
  const avgAll = allPcts.length ? Math.round(allPcts.reduce((a,b)=>a+b,0)/allPcts.length) : 0;
  const wajibPcts = HARIAN.filter(t=>t.prioritas==='Wajib').map(t=>taskPcts[t.kode]||0);
  const avgWajib = wajibPcts.length ? Math.round(wajibPcts.reduce((a,b)=>a+b,0)/wajibPcts.length) : 0;
  const pentingPcts = HARIAN.filter(t=>t.prioritas==='Penting').map(t=>taskPcts[t.kode]||0);
  const avgPenting = pentingPcts.length ? Math.round(pentingPcts.reduce((a,b)=>a+b,0)/pentingPcts.length) : 0;

  function avgCell(v) {
    const cls = v>=90?'pct-hi':v>=70?'pct-mid':'pct-lo';
    return `<td colspan="${daysInMonth}" style="text-align:left;padding-left:12px"><span class="grid-pct ${cls}">${v}%</span></td><td></td>`;
  }

  cont.innerHTML = `
    <div class="grid-wrap">
      <table class="grid-table">
        <thead>
          <tr>
            <th class="task-col">Tugas</th>
            ${headerDays}
            <th>%</th>
          </tr>
        </thead>
        <tbody>
          ${rows}
          <tr class="grid-avg-row">
            <td class="task-info" style="background:var(--card2)">RATA-RATA SEMUA</td>
            ${avgCell(avgAll)}
          </tr>
          <tr class="grid-avg-row">
            <td class="task-info" style="background:var(--card2)">Rata-rata WAJIB 🔴</td>
            ${avgCell(avgWajib)}
          </tr>
          <tr class="grid-avg-row">
            <td class="task-info" style="background:var(--card2)">Rata-rata PENTING 🟡</td>
            ${avgCell(avgPenting)}
          </tr>
        </tbody>
      </table>
    </div>
  `;
}

// ─────────────────────────────────────────────
// LAPORAN
// ─────────────────────────────────────────────
async function loadLaporan() {
  if (!scriptUrl) { openModal(); return; }
  const bulan = document.getElementById('laporan-month').value;
  if (!bulan) return;

  const cont = document.getElementById('laporan-container');
  cont.innerHTML = '<div class="empty"><span class="spinner"></span> Memuat laporan...</div>';

  try {
    const r = await fetch(`${scriptUrl}?type=grid&bulan=${bulan}`);
    const d = await r.json();
    renderLaporan(d, bulan);
  } catch(e) {
    cont.innerHTML = '<div class="empty"><div class="empty-icon">⚠</div><div class="empty-text">Gagal memuat laporan</div></div>';
  }
}

function renderLaporan(data, bulan) {
  const cont = document.getElementById('laporan-container');
  const [yr, mo] = bulan.split('-').map(Number);
  const daysInMonth = new Date(yr, mo, 0).getDate();
  const bulanName = BULAN_NAMES[mo-1] + ' ' + yr;

  // Map data
  const dataMap = {};
  (data.rows || []).forEach(row => {
    const kode = row[1];
    if (!dataMap[kode]) dataMap[kode] = {};
    const day = parseInt((row[0]||'').split('-')[2]) || 0;
    if (day) dataMap[kode][day] = row[5];
  });

  // Build weeks
  const weeks = [];
  let weekStart = 1;
  while (weekStart <= daysInMonth) {
    let weekEnd = weekStart;
    while (weekEnd < daysInMonth && new Date(yr, mo-1, weekEnd+1).getDay() !== 1) weekEnd++;
    weeks.push({start: weekStart, end: weekEnd});
    weekStart = weekEnd + 1;
  }

  // Notif: tugas < 70% keseluruhan bulan
  const taskPcts = {};
  let notifHTML = '';
  const pastDays = Array.from({length:daysInMonth},(_,i)=>i+1)
    .filter(d => new Date(yr,mo-1,d).getDay()!==0 && new Date(yr,mo-1,d)<new Date());

  HARIAN.forEach(t => {
    const td = dataMap[t.kode] || {};
    const done = pastDays.filter(d => td[d]==='✓').length;
    const pct = pastDays.length > 0 ? Math.round(done/pastDays.length*100) : null;
    taskPcts[t.kode] = pct;
    if (pct !== null && pct < 70) {
      notifHTML += `<div class="notif-item warn">⚠ ${t.kode} · ${t.nama}: hanya <b>${pct}%</b> (target ≥ 70%)</div>`;
    }
  });

  // Bar chart: % per minggu (rata-rata semua tugas)
  const weekPcts = weeks.map(w => {
    const wDays = Array.from({length:w.end-w.start+1},(_,i)=>w.start+i)
      .filter(d => new Date(yr,mo-1,d).getDay()!==0 && new Date(yr,mo-1,d)<new Date());
    if (!wDays.length) return null;
    const allDone = HARIAN.reduce((sum, t) => {
      const td = dataMap[t.kode] || {};
      return sum + wDays.filter(d => td[d]==='✓').length;
    }, 0);
    const total = HARIAN.length * wDays.length;
    return total > 0 ? Math.round(allDone/total*100) : 0;
  });

  const maxPct = Math.max(...weekPcts.filter(p=>p!==null), 1);
  let barsHTML = weekPcts.map((p, i) => {
    if (p === null) return `<div class="bar-col"><div class="bar-label">Mg ${i+1}</div></div>`;
    const h = Math.round((p/100)*80);
    const color = p>=90?'var(--green)':p>=70?'var(--orange)':'var(--red)';
    return `<div class="bar-col">
      <div class="bar-val">${p}%</div>
      <div class="bar-rect" style="height:${h}px;background:${color}"></div>
      <div class="bar-label">Mg ${i+1}</div>
    </div>`;
  }).join('');

  // Week detail tables
  let weeksHTML = weeks.map((w, wi) => {
    const wLabel = `Minggu ${wi+1}: ${w.start}–${w.end}/${mo.toString().padStart(2,'0')}`;
    const wDays = Array.from({length:w.end-w.start+1},(_,i)=>w.start+i)
      .filter(d => new Date(yr,mo-1,d).getDay()!==0 && new Date(yr,mo-1,d)<new Date());

    const wPct = weekPcts[wi];
    if (wPct === null) return '';

    const pctColor = wPct>=90?'var(--green)':wPct>=70?'var(--orange)':'var(--red)';

    const taskRows = HARIAN.map(t => {
      const td = dataMap[t.kode] || {};
      const done = wDays.filter(d => td[d]==='✓').length;
      const pct = wDays.length > 0 ? Math.round(done/wDays.length*100) : 0;
      const barColor = pct>=90?'var(--green)':pct>=70?'var(--orange)':'var(--red)';
      const pctTxt = wDays.length > 0 ? pct+'%' : '—';
      return `<div class="laporan-task-row">
        <div class="lt-kode">${t.kode}</div>
        <div class="lt-name">${t.nama}</div>
        <div class="lt-bar-wrap"><div class="lt-bar-fill" style="width:${pct}%;background:${barColor}"></div></div>
        <div class="lt-pct" style="color:${barColor}">${pctTxt}</div>
      </div>`;
    }).join('');

    return `<div class="laporan-week">
      <div class="week-title">${wLabel}</div>
      <div class="week-avg" style="color:${pctColor}">${wPct}%</div>
      <div style="font-size:11px;color:var(--muted);margin-bottom:10px">rata-rata semua tugas</div>
      ${taskRows}
    </div>`;
  }).join('');

  cont.innerHTML = `
    ${notifHTML ? `<div class="notif-list">${notifHTML}</div>` : ''}
    <div class="chart-wrap">
      <div class="chart-title">% Penyelesaian per Minggu — ${bulanName}</div>
      <div class="bar-chart">${barsHTML}</div>
    </div>
    ${weeksHTML || '<div class="empty"><div class="empty-icon">📭</div><div class="empty-text">Belum ada data untuk bulan ini</div></div>'}
  `;
}

// ─────────────────────────────────────────────
// RIWAYAT
// ─────────────────────────────────────────────
async function loadRiwayat() {
  if (!scriptUrl) { openModal(); return; }
  const bulan = document.getElementById('riwayat-month').value;
  if (!bulan) return;

  const cont = document.getElementById('riwayat-container');
  cont.innerHTML = '<div class="empty"><span class="spinner"></span> Memuat riwayat...</div>';

  try {
    const [rH, rE] = await Promise.all([
      fetch(`${scriptUrl}?type=harian&bulan=${bulan}`).then(r=>r.json()).catch(()=>null),
      fetch(`${scriptUrl}?type=event&bulan=${bulan}`).then(r=>r.json()).catch(()=>null),
    ]);
    renderRiwayat(rH, rE, bulan);
  } catch(e) {
    cont.innerHTML = '<div class="empty">Gagal memuat riwayat</div>';
  }
}

function renderRiwayat(rH, rE, bulan) {
  const cont = document.getElementById('riwayat-container');
  const [yr, mo] = bulan.split('-').map(Number);

  // Group harian by date
  const byDate = {};
  (rH?.rows || []).forEach(row => {
    const tgl = row[0]; if (!tgl) return;
    if (!byDate[tgl]) byDate[tgl] = [];
    byDate[tgl].push({kode:row[1], nama:row[2], status:row[5], catatan:row[6]});
  });

  const dates = Object.keys(byDate).sort().reverse();
  if (!dates.length && !(rE?.rows?.length)) {
    cont.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><div class="empty-text">Belum ada data untuk bulan ini</div></div>';
    return;
  }

  let html = '';

  // Harian history
  if (dates.length) {
    html += `<div class="section-hdr"><span class="section-hdr-label">Tugas Harian</span><div class="section-hdr-line"></div></div>`;
    dates.forEach(tgl => {
      const tasks = byDate[tgl];
      const done = tasks.filter(t=>t.status==='✓').length;
      const pct = Math.round(done/tasks.length*100);
      const tags = tasks.map(t =>
        `<span class="history-tag ${t.status==='✓'?'done':'skip'}">${t.kode}</span>`
      ).join('');
      const d = new Date(tgl);
      const label = `${d.getDate()} ${BULAN_NAMES[d.getMonth()]} — ${DAY_SHORT[d.getDay()]}`;
      html += `<div class="history-item">
        <div class="history-date">${label}</div>
        <div class="history-tasks">${tags}</div>
        <div class="history-summary">${done}/${tasks.length} selesai (${pct}%)</div>
      </div>`;
    });
  }

  // Event history
  if (rE?.rows?.length) {
    html += `<div class="section-hdr" style="margin-top:16px"><span class="section-hdr-label">Tugas Non-Harian</span><div class="section-hdr-line"></div></div>`;
    [...rE.rows].reverse().forEach(row => {
      const [tgl,,kode,nama,,,,status,catatan] = row;
      if (!tgl) return;
      const d = new Date(tgl);
      const label = `${d.getDate()} ${BULAN_NAMES[d.getMonth()]}`;
      html += `<div class="history-item">
        <div class="history-date">${label} · ${kode}</div>
        <div style="font-size:12px;font-weight:500">${nama}</div>
        <div class="history-summary" style="margin-top:4px">Status: <span style="color:${status==='✓'?'var(--green)':'var(--red)'}">${status}</span>${catatan?' · '+catatan:''}</div>
      </div>`;
    });
  }

  cont.innerHTML = html;
}

// ─────────────────────────────────────────────
// MODAL & URL
// ─────────────────────────────────────────────
function openModal() {
  document.getElementById('url-input').value = scriptUrl;
  document.getElementById('modal').classList.add('open');
}
function closeModal() {
  document.getElementById('modal').classList.remove('open');
}
function saveUrl() {
  const val = document.getElementById('url-input').value.trim();
  if (!val.startsWith('http')) { showToast('URL tidak valid', 'err'); return; }
  scriptUrl = val;
  localStorage.setItem('mtg_url', val);
  updateConnected();
  closeModal();
  showToast('URL tersimpan ✓', 'ok');
  checkTodayFilled();
  checkLaporanBadge();
}
function updateConnected() {
  document.getElementById('setup-dot').className = 'setup-dot' + (scriptUrl ? ' connected' : '');
}

// ─────────────────────────────────────────────
// TOAST
// ─────────────────────────────────────────────
let _toastTimer;
function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type?' '+type:'');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}

// Close modal on bg click
document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
